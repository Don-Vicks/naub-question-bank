# Base URL of the NestJS backend (question-bank-pipeline project)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Set to "true" to develop against lib/mock-data.ts instead of a real
# backend - useful right now since the backend only has ingestion/review
# endpoints, not yet the browse/search read endpoints this frontend expects.
# See lib/api.ts for the exact endpoints still needed server-side.
NEXT_PUBLIC_USE_MOCKS=true
